# Android release signing for the LOAM host — copy this to `keystore.properties` (gitignored) or,
# simpler, just run `pnpm --filter app keystore` to generate a key and write that file for you.
#
# When keystore.properties is present, `pnpm --filter app apk` signs the release APK with this key
# (via plugins/with-release-signing.js). When it's absent, the release APK is signed with the debug
# key — fine for `adb install`, not for durable distribution.
#
# storeFile may be relative to apps/app (as below) or an absolute path.
storeFile=release.jks
storePassword=CHANGE_ME
keyAlias=loam
keyPassword=CHANGE_ME
