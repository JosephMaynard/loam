{
  "expo": {
    "name": "LOAM",
    "slug": "loam",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/loam-icon.png",
    "scheme": "loam",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/loam-icon.png"
    },
    "android": {
      "package": "com.loamnet.host",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#d14900",
        "foregroundImage": "./assets/images/loam-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/loam-icon.png"
    },
    "plugins": [
      "expo-router",
      "llama.rn",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#d14900",
          "image": "./assets/images/loam-splash.png",
          "imageWidth": 200
        }
      ],
      "./plugins/with-loam-host",
      "./plugins/with-release-signing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
